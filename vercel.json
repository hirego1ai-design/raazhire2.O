{
    "version": 2,
    "name": "hirego-platform",
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        },
        {
            "src": "server/index.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "server/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "server/index.js"
        },
        {
            "src": "/health",
            "dest": "server/index.js"
        },
        {
            "src": "/(.*)",
            "dest": "index.html"
        }
    ]
}